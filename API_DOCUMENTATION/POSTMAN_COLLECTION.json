  "item": [
    {
      "name": "1 - Authentication",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has success field', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('success');",
                  "});",
                  "pm.test('Registration is successful', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.message).to.include('successful');",
                  "});",
                  "pm.test('User object returned', function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.success) {",
                  "        pm.expect(jsonData.user).to.have.property('id');",
                  "        pm.expect(jsonData.user).to.have.property('email');",
                  "        pm.expect(jsonData.user.role).to.eql('user');",
                  "        pm.collectionVariables.set('userId', jsonData.user.id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Student\",\n  \"email\": \"teststudent{{$randomInt}}@example.com\",\n  \"phone\": \"9{{$randomInt}}99999\",\n  \"password\": \"test1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPath}}/register.php",
              "host": ["{{baseUrl}}{{apiPath}}"],
              "path": ["register.php"]
            },
            "description": "Register a new user. Auto-logs in on success and sets PHPSESSID cookie."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Login is successful', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.message).to.include('Login successful');",
                  "});",
                  "pm.test('User data returned', function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.success) {",
                  "        pm.expect(jsonData.user.email).to.eql(pm.collectionVariables.get('email'));",
                  "        pm.collectionVariables.set('userId', jsonData.user.id);",
                  "    }",
                  "});",
                  "pm.test('Content-Type is JSON', function () {",
                  "    pm.response.to.have.header('Content-Type');",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"remember\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPath}}/login.php",
              "host": ["{{baseUrl}}{{apiPath}}"],
              "path": ["login.php"]
            },
            "description": "Login with email and password. PHPSESSID cookie is set in the Postman Cookie Jar."
          }
        },
        {
          "name": "Login - Wrong Password (Negative Test)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "pm.test('Success is false', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(false);",
                  "});",
                  "pm.test('Error message present', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('Invalid email or password');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPath}}/login.php",
              "host": ["{{baseUrl}}{{apiPath}}"],
              "path": ["login.php"]
            },
            "description": "NEGATIVE TEST: Attempt login with wrong password. Expects HTTP 401."
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Redirect happens (3xx or 200)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 301, 302]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/logout.php",
              "host": ["{{baseUrl}}"],
              "path": ["logout.php"]
            },
            "description": "Logs out the current user. Destroys PHP session and clears cookies."
          }
        }
      ]
    },
