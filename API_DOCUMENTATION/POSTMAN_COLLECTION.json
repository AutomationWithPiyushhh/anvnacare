{
  "info": {
    "_postman_id": "anvnacare-api-collection-v1",
    "name": "ANVNA Care API Collection",
    "description": "Complete REST API collection for ANVNA Care healthcare platform.\n\nBASE URL: https://anvnacare.alwaysdata.net\n\n⚠️ IMPORTANT: This API uses PHP Session-based authentication.\n1. First call the Login request.\n2. The PHPSESSID cookie will be set automatically.\n3. Postman Cookie Jar must be enabled.\n4. For all POST/PUT/DELETE requests, include the CSRF token.\n   Get the CSRF token by calling the Login endpoint - it is stored in your PHP session.\n   Use the X-CSRF-Token header or include it in the request body as 'csrf_token'.\n\nTEST CREDENTIALS:\n  Admin: admin@anvnacare.com / password123\n  User:  amit.kumar@anvnacare.com / password123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://anvnacare.alwaysdata.net",
      "type": "string"
    },
    {
      "key": "apiPath",
      "value": "/api",
      "type": "string"
    },
    {
      "key": "email",
      "value": "amit.kumar@anvnacare.com",
      "type": "string"
    },
    {
      "key": "password",
      "value": "password123",
      "type": "string"
    },
    {
      "key": "csrfToken",
